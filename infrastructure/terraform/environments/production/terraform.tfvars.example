# Copy this file to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars to source control.

subscription_id = "00000000-0000-0000-0000-000000000000"

project     = "trophic"
environment = "prod"
location    = "eastus2"

kubernetes_version = "1.31"

db_admin_username = "trophicadmin"
db_admin_password = "CHANGE_ME_use_az_keyvault_or_vault"

auth_secret  = "CHANGE_ME_openssl_rand_base64_32"
app_hostname = "app.trophictech.io"

alert_email       = "platform@trophictech.io"
slack_webhook_url = "https://hooks.slack.com/services/XXX/YYY/ZZZ"

# Uncomment to add a secondary Azure region for ACR geo-replication:
# acr_georeplication_locations = ["westus2"]
