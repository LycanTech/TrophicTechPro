# ─── Provider & Version Constraints ────────────────────────────────────────────
# Pin provider versions so CI always produces identical plans.
# Upgrade deliberately: run `terraform init -upgrade` and review the diff.

terraform {
  required_version = ">= 1.9.0"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 4.0"
    }
    azuread = {
      source  = "hashicorp/azuread"
      version = "~> 3.0"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }
}
