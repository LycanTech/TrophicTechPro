# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/trophic_mc"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Azure Container Registry (used by CI/CD)
ACR_REGISTRY="trophictech.azurecr.io"
ACR_REPOSITORY="mission-control"

# Azure (used by CI/CD)
AZURE_CREDENTIALS=""
AKS_CLUSTER="trophic-aks"
AKS_RESOURCE_GROUP="trophic-rg"

# Notifications (used by CI/CD)
SLACK_WEBHOOK_URL=""
CODECOV_TOKEN=""
